# ════════════════════════════════════════════════════════════
# LUMEO AI — Telegram Bot Environment Variables
# EMEMZYVISUALS DIGITALS | Emmanuel.A
# ════════════════════════════════════════════════════════════

# ── Telegram ────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_from_botfather

# ── Admin Telegram IDs (comma-separated) ────────────────────
# Get your ID from @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# ── Telegram Channel (for auto-posts) ───────────────────────
# Use @channelname or -100xxxxxxxxxx
CHANNEL_ID=@lumeoaichannel

# ── Mini App URL ─────────────────────────────────────────────
MINI_APP_URL=https://your-render-url.onrender.com/app

# ── Groq AI ─────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── HuggingFace (3 tokens for rotation) ─────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_2=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_TOKEN_3=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email outreach ───────────────────────────────────────────
EMAIL_USER=ememzyvisualsdigitals@gmail.com
EMAIL_PASS=your_gmail_app_password

# ── Genius API (lyrics links, optional) ─────────────────────
GENIUS_KEY=your_genius_api_key

# ── Port (Render sets this automatically) ───────────────────
PORT=3000

# ── yt-dlp (suppress update noise) ──────────────────────────
YTDL_NO_UPDATE=1

# ── Group IDs ────────────────────────────────────────────────────────────────
# Get group ID by adding @userinfobot to the group and sending /start
ALGIVIX_GROUP_ID=-1001234567890
# Additional groups (comma-separated)
EXTRA_GROUP_IDS=-1009876543210,-1001122334455

# ── Bot Username (without @) ──────────────────────────────────────────────────
BOT_USERNAME=LumeoAIBot
-e 
# ── Render URL (for internal self-pinger) ────────────────────────────────────
RENDER_EXTERNAL_URL=https://lumeo-tel-bot.onrender.com
